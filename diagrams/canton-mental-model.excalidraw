    { "type": "text", "id": "tvsell", "x": 660, "y": 1775, "width": 500, "height": 110, "text": "SELLER's VIEW\n\nCash in, title out.\nFull detail of its own legs only.", "fontSize": 16, "fontFamily": 1, "strokeColor": "#1e1e1e", "textAlign": "center", "verticalAlign": "middle", "containerId": "v_sell", "originalText": "SELLER's VIEW\n\nCash in, title out.\nFull detail of its own legs only.", "autoResize": true },

    { "type": "rectangle", "id": "v_reg", "x": 1210, "y": 1755, "width": 540, "height": 150, "roundness": { "type": 3 }, "backgroundColor": "#b2f2bb", "fillStyle": "solid", "strokeColor": "#2f9e44", "boundElements": [{ "id": "tvreg", "type": "text" }] },
    { "type": "text", "id": "tvreg", "x": 1230, "y": 1775, "width": 500, "height": 110, "text": "REGULATOR's VIEW\n(observer)\n\nSees that a VALID settlement\nfinalized - and nothing more.", "fontSize": 16, "fontFamily": 1, "strokeColor": "#1e1e1e", "textAlign": "center", "verticalAlign": "middle", "containerId": "v_reg", "originalText": "REGULATOR's VIEW\n(observer)\n\nSees that a VALID settlement\nfinalized - and nothing more.", "autoResize": true },

