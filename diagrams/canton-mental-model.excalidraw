    { "type": "text", "id": "tvout", "x": 1800, "y": 1775, "width": 495, "height": 110, "text": "OUTSIDER / COMPETITOR\n\nSees NOTHING.\nNot a party  ->  no data at all.\nThis is the moat.", "fontSize": 16, "fontFamily": 1, "strokeColor": "#1e1e1e", "textAlign": "center", "verticalAlign": "middle", "containerId": "v_out", "originalText": "OUTSIDER / COMPETITOR\n\nSees NOTHING.\nNot a party  ->  no data at all.\nThis is the moat.", "autoResize": true }
