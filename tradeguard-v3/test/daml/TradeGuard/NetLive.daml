--
-- | Live-network multilateral netting scenario.
--
-- Seeds a confidential 3-firm obligation book on the real ledger, then runs the
-- full netting: the operator (agent principal) computes the minimal residual set,
-- proposes a NettingBatch, and settles it atomically (discharge all obligations +
-- move only the residual cash). Idempotent party get-or-allocate so it can run
-- repeatedly against the same network.
module TradeGuard.NetLive where

import DA.Optional (fromOptional)
import DA.List (find)
import DA.Text (splitOn)
import qualified DA.Set as Set
import Daml.Script

import TradeGuard.Types
import TradeGuard.Holding
import TradeGuard.Instrument
import TradeGuard.Settlement
import TradeGuard.Netting

-- | Get-or-allocate a party by id-prefix hint (idempotent across runs).
getOrAllocate : Text -> Script Party
getOrAllocate hint = do
  existing <- listKnownParties
  let hasHint d = case splitOn "::" (partyToText d.party) of
        (prefix :: _) -> prefix == hint
        [] -> False
  case find hasHint existing of
    Some d -> pure d.party
    None -> allocatePartyWithHint hint (PartyIdHint hint)

data NetLiveResult = NetLiveResult with
  firmA : Party
  firmB : Party
  firmC : Party
  operator : Party
  bank : Party
  obligationsDischarged : Int
  residualsSettled : Int
  grossValue : Decimal
  netValue : Decimal
    deriving (Eq, Show)

-- | Seed ONLY the obligation book (no settlement), so privacy can be observed
--   while obligations are still active. Returns the firm parties.
seedNetBookOnly : Script NetLiveResult
seedNetBookOnly = do
  firmA <- getOrAllocate "FirmA"
  firmB <- getOrAllocate "FirmB"
  firmC <- getOrAllocate "FirmC"
  operator <- getOrAllocate "Operator"
  bank <- getOrAllocate "NetBank"
  let usd = InstrumentKey with
        depository = bank; issuer = bank; id = Id "USD"; version = "1"
        holdingStandard = TransferableFungible
  _ <- submitMulti [firmA, firmB] [] do createCmd Obligation with payer = firmA; payee = firmB; operator; instrument = usd; amount = 100.0; reference = "A->B inv1"
  _ <- submitMulti [firmB, firmC] [] do createCmd Obligation with payer = firmB; payee = firmC; operator; instrument = usd; amount = 100.0; reference = "B->C inv2"
  _ <- submitMulti [firmC, firmA] [] do createCmd Obligation with payer = firmC; payee = firmA; operator; instrument = usd; amount = 80.0; reference = "C->A inv3"
  _ <- submitMulti [firmA, firmC] [] do createCmd Obligation with payer = firmA; payee = firmC; operator; instrument = usd; amount = 50.0; reference = "A->C inv4"
  _ <- submitMulti [firmC, firmB] [] do createCmd Obligation with payer = firmC; payee = firmB; operator; instrument = usd; amount = 30.0; reference = "C->B inv5"
  pure NetLiveResult with
    firmA; firmB; firmC; operator; bank
    obligationsDischarged = 0; residualsSettled = 0; grossValue = 360.0; netValue = 70.0

-- | Full live netting: seed the book, compute residuals, settle atomically.
runNetLive : Script NetLiveResult
runNetLive = do
  firmA <- getOrAllocate "FirmA"
  firmB <- getOrAllocate "FirmB"
  firmC <- getOrAllocate "FirmC"
  operator <- getOrAllocate "Operator"
  bank <- getOrAllocate "NetBank"
  regulator <- getOrAllocate "NetReg"

  let usd = InstrumentKey with
        depository = bank; issuer = bank; id = Id "USD"; version = "1"
        holdingStandard = TransferableFungible

  -- register USD (idempotent)
  instrs <- query @Instrument bank
  cashI <- case find (\(_, i) -> i.id == Id "USD") instrs of
    Some (cid, _) -> pure cid
    None -> submit bank do
      createCmd Instrument with
        depository = bank; issuer = bank; id = Id "USD"; version = "1"
        holdingStandard = TransferableFungible
        description = "USD tokenized deposit"; observers = Set.empty

  -- cash accounts (idempotent)
  let mkAcct owner accId = do
        accts <- query @Account bank
        case find (\(_, a) -> a.owner == owner && a.id == Id accId) accts of
          Some _ -> pure ()
          None -> do
            _ <- submitMulti [bank, owner] [] do
              createCmd Account with custodian = bank; owner; id = Id accId; observers = Set.empty
            pure ()
  mkAcct firmA "A-cash"
  mkAcct firmB "B-cash"
  mkAcct firmC "C-cash"

  -- fund A (the sole net payer) with its residual 70 (two holdings: 40 + 30)
  aCash40 <- submitMulti [bank, firmA] [] do
    exerciseCmd cashI Issue with custodian = bank; owner = firmA; accountId = Id "A-cash"; amount = 40.0
  aCash30 <- submitMulti [bank, firmA] [] do
    exerciseCmd cashI Issue with custodian = bank; owner = firmA; accountId = Id "A-cash"; amount = 30.0

  -- operator settlement authority (idempotent)
  auths <- query @SettlementAuthority bank
  auth <- case find (\(_, a) -> a.coordinator == operator) auths of
    Some (cid, _) -> pure cid
    None -> submit bank do createCmd SettlementAuthority with custodian = bank; coordinator = operator

  -- the confidential obligation book (each disclosed only to its 2 firms + operator)
  o1 <- submitMulti [firmA, firmB] [] do createCmd Obligation with payer = firmA; payee = firmB; operator; instrument = usd; amount = 100.0; reference = "A->B inv1"
  o2 <- submitMulti [firmB, firmC] [] do createCmd Obligation with payer = firmB; payee = firmC; operator; instrument = usd; amount = 100.0; reference = "B->C inv2"
  o3 <- submitMulti [firmC, firmA] [] do createCmd Obligation with payer = firmC; payee = firmA; operator; instrument = usd; amount = 80.0; reference = "C->A inv3"
  o4 <- submitMulti [firmA, firmC] [] do createCmd Obligation with payer = firmA; payee = firmC; operator; instrument = usd; amount = 50.0; reference = "A->C inv4"
  o5 <- submitMulti [firmC, firmB] [] do createCmd Obligation with payer = firmC; payee = firmB; operator; instrument = usd; amount = 30.0; reference = "C->B inv5"

  let obls = [o1, o2, o3, o4, o5]
      facts =
        [ NetTransfer firmA firmB 100.0 (Some "USD"), NetTransfer firmB firmC 100.0 (Some "USD")
        , NetTransfer firmC firmA 80.0 (Some "USD"), NetTransfer firmA firmC 50.0 (Some "USD")
        , NetTransfer firmC firmB 30.0 (Some "USD") ]
      -- agent-computed minimal residuals: A->C 40, A->B 30
      legAC = Leg with sender = firmA; receiver = firmC; custodian = bank; instrument = usd; amount = 40.0; senderAccountId = Id "A-cash"; receiverAccountId = Id "C-cash"
      legAB = Leg with sender = firmA; receiver = firmB; custodian = bank; instrument = usd; amount = 30.0; senderAccountId = Id "A-cash"; receiverAccountId = Id "B-cash"

  batch <- submit operator do
    createCmd NettingBatch with
      operator; obligations = obls; obligationFacts = facts
      residualLegs = [legAC, legAB]; cashInstrument = usd; creditLimits = Some []; fxRates = None; liquidityFloors = None; balanceFacts = None; valuationCurrency = None
      parties = Set.fromList [firmA, firmB, firmC]
      regulator = Some regulator; status = Pending

  locked40 <- submitMulti [bank, firmA] [] do exerciseCmd aCash40 LockHolding with locker = operator; context = "net-live"
  locked30 <- submitMulti [bank, firmA] [] do exerciseCmd aCash30 LockHolding with locker = operator; context = "net-live"
  let allocs =
        [ AllocatedLeg with leg = legAC; holdingCid = locked40; authorityCid = auth
        , AllocatedLeg with leg = legAB; holdingCid = locked30; authorityCid = auth ]

  result <- submitMulti (operator :: [firmA, firmB, firmC]) [] do
    exerciseCmd batch SettleNetting with allocations = allocs

  pure NetLiveResult with
    firmA; firmB; firmC; operator; bank
    obligationsDischarged = result.obligationsDischarged
    residualsSettled = result.residualsSettled
    grossValue = result.grossValue
    netValue = result.netValue

-- | Settle the obligation book that ALREADY EXISTS on the ledger (seeded separately,
--   e.g. by the Operator Console). Finds the operator's visible obligations, rebuilds
--   their facts, funds the net payer, and settles the residuals atomically. This is
--   what the console's "Approve & settle" calls so seed and settle operate on the
--   same book (unlike runNetLive, which seeds its own).
settleSeededBook : Script NetLiveResult
settleSeededBook = do
  firmA <- getOrAllocate "FirmA"
  firmB <- getOrAllocate "FirmB"
  firmC <- getOrAllocate "FirmC"
  operator <- getOrAllocate "Operator"
  bank <- getOrAllocate "NetBank"
  regulator <- getOrAllocate "NetReg"
  let usd = InstrumentKey with
        depository = bank; issuer = bank; id = Id "USD"; version = "1"
        holdingStandard = TransferableFungible

  -- find the existing obligations the operator can see (the seeded book)
  obRows <- query @Obligation operator
  let obls  = map fst obRows
      facts = map (\(_, o) -> NetTransfer o.payer o.payee o.amount (Some (unId o.instrument.id))) obRows
  assertMsg "no seeded book to settle" (not (null obls))

  -- register USD + accounts (idempotent)
  instrs <- query @Instrument bank
  cashI <- case find (\(_, i) -> i.id == Id "USD") instrs of
    Some (cid, _) -> pure cid
    None -> submit bank do
      createCmd Instrument with depository = bank; issuer = bank; id = Id "USD"; version = "1"; holdingStandard = TransferableFungible; description = "USD"; observers = Set.empty
  let mkAcct owner accId = do
        accts <- query @Account bank
        case find (\(_, a) -> a.owner == owner && a.id == Id accId) accts of
          Some _ -> pure ()
          None -> do _ <- submitMulti [bank, owner] [] do
                       createCmd Account with custodian = bank; owner; id = Id accId; observers = Set.empty
                     pure ()
  mkAcct firmA "A-cash"; mkAcct firmB "B-cash"; mkAcct firmC "C-cash"

  -- net positions from the facts: A is the sole net payer in this scenario,
  -- so it pays each receiver its net (toC, toB) and all obligations discharge.
  let aNet = sum [t.amount | t <- facts, t.receiver == firmA]
           - sum [t.amount | t <- facts, t.sender == firmA]
      bNet = sum [t.amount | t <- facts, t.receiver == firmB]
           - sum [t.amount | t <- facts, t.sender == firmB]
      cNet = sum [t.amount | t <- facts, t.receiver == firmC]
           - sum [t.amount | t <- facts, t.sender == firmC]
      toC = cNet
      toB = bNet
  assertMsg "scenario assumes A is sole net payer" (aNet < 0.0 && bNet >= 0.0 && cNet >= 0.0)

  -- fund A with its residual (two holdings sized to the receivers' nets)
  aCashC <- submitMulti [bank, firmA] [] do
    exerciseCmd cashI Issue with custodian = bank; owner = firmA; accountId = Id "A-cash"; amount = toC
  aCashB <- submitMulti [bank, firmA] [] do
    exerciseCmd cashI Issue with custodian = bank; owner = firmA; accountId = Id "A-cash"; amount = toB

  auths <- query @SettlementAuthority bank
  auth <- case find (\(_, a) -> a.coordinator == operator) auths of
    Some (cid, _) -> pure cid
    None -> submit bank do createCmd SettlementAuthority with custodian = bank; coordinator = operator

  let legAC = Leg with sender = firmA; receiver = firmC; custodian = bank; instrument = usd; amount = toC; senderAccountId = Id "A-cash"; receiverAccountId = Id "C-cash"
      legAB = Leg with sender = firmA; receiver = firmB; custodian = bank; instrument = usd; amount = toB; senderAccountId = Id "A-cash"; receiverAccountId = Id "B-cash"
  batch <- submit operator do
    createCmd NettingBatch with
      operator; obligations = obls; obligationFacts = facts
      residualLegs = [legAC, legAB]; cashInstrument = usd; creditLimits = Some []; fxRates = None; liquidityFloors = None; balanceFacts = None; valuationCurrency = None
      parties = Set.fromList [firmA, firmB, firmC]
      regulator = Some regulator; status = Pending

  lockedC <- submitMulti [bank, firmA] [] do exerciseCmd aCashC LockHolding with locker = operator; context = "console-net"
  lockedB <- submitMulti [bank, firmA] [] do exerciseCmd aCashB LockHolding with locker = operator; context = "console-net"
  let allocs = [ AllocatedLeg with leg = legAC; holdingCid = lockedC; authorityCid = auth
               , AllocatedLeg with leg = legAB; holdingCid = lockedB; authorityCid = auth ]
  result <- submitMulti (operator :: [firmA, firmB, firmC]) [] do
    exerciseCmd batch SettleNetting with allocations = allocs

  pure NetLiveResult with
    firmA; firmB; firmC; operator; bank
    obligationsDischarged = result.obligationsDischarged
    residualsSettled = result.residualsSettled
    grossValue = result.grossValue
    netValue = result.netValue

