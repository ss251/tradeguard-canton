--
-- | Tests for private multilateral netting — the settlement-optimization core.
--
-- Proves:
--   * a 3-party obligation book nets down to minimal residual transfers,
--   * the net settles atomically (obligations discharged + residual cash moved),
--   * conservation is enforced on-ledger (the adversarial guard rejects a
--     value-violating proposal),
--   * efficiency is enforced (residual gross cannot exceed obligation gross),
--   * privacy: each firm sees only its own obligations, never the whole book.
module TradeGuard.Test.Netting where

import DA.Assert ((===))
import DA.Optional (isNone)
import DA.Foldable (forA_)
import qualified DA.Set as Set
import Daml.Script

import TradeGuard.Types
import TradeGuard.Holding
import TradeGuard.Instrument
import TradeGuard.Settlement
import TradeGuard.Netting
import TradeGuard.Test.Setup (findAuth)

-- | A three-firm book + an operator (the agent principal) + a cash custodian.
data NetWorld = NetWorld with
  firmA : Party
  firmB : Party
  firmC : Party
  operator : Party
  bank : Party       -- cash custodian + depository
  regulator : Party
  outsider : Party
  usd : InstrumentKey

setupNetWorld : Script NetWorld
setupNetWorld = do
  firmA <- allocatePartyWithHint "FirmA" (PartyIdHint "FirmA")
  firmB <- allocatePartyWithHint "FirmB" (PartyIdHint "FirmB")
  firmC <- allocatePartyWithHint "FirmC" (PartyIdHint "FirmC")
  operator <- allocatePartyWithHint "Operator" (PartyIdHint "Operator")
  bank <- allocatePartyWithHint "NetBank" (PartyIdHint "NetBank")
  regulator <- allocatePartyWithHint "NetReg" (PartyIdHint "NetReg")
  outsider <- allocatePartyWithHint "NetOut" (PartyIdHint "NetOut")
  let usd = InstrumentKey with
        depository = bank; issuer = bank; id = Id "USD"; version = "1"
        holdingStandard = TransferableFungible
  pure NetWorld with ..

-- helpers ---------------------------------------------------------------------

mkObligation : Party -> Party -> Party -> InstrumentKey -> Decimal -> Text -> Script (ContractId Obligation)
mkObligation payer payee operator instrument amount reference =
  submitMulti [payer, payee] [] do
    createCmd Obligation with payer; payee; operator; instrument; amount; reference

mkCashAccount : Party -> Party -> Text -> Script ()
mkCashAccount bank owner accId = do
  _ <- submitMulti [bank, owner] [] do
    createCmd Account with custodian = bank; owner; id = Id accId; observers = Set.empty
  pure ()

issueCash : ContractId Instrument -> Party -> Party -> Text -> Decimal -> Script (ContractId Holding)
issueCash instrI bank owner accId amount =
  submitMulti [bank, owner] [] do
    exerciseCmd instrI Issue with custodian = bank; owner; accountId = Id accId; amount

-- | THE HEADLINE TEST: a 3-firm book nets to minimal residuals and settles
--   atomically. Book (all USD):
--     A owes B 100 ; B owes C 100 ; C owes A 80 ; A owes C 50 ; C owes B 30
--   Net positions: A = -70 (pays) ; B = +30 (recv) ; C = +40 (recv)
--   Minimal residuals: A->C 40, A->B 30  (gross 360 -> net 70, 80.6% netted out)
testThreePartyNetting : Script ()
testThreePartyNetting = do
  w <- setupNetWorld
  -- register USD + fund the only net payer (A) with its residual 70
  cashI <- submit w.bank do
    createCmd Instrument with
      depository = w.bank; issuer = w.bank; id = Id "USD"; version = "1"
      holdingStandard = TransferableFungible
      description = "USD"; observers = Set.empty
  mkCashAccount w.bank w.firmA "A-cash"
  mkCashAccount w.bank w.firmB "B-cash"
  mkCashAccount w.bank w.firmC "C-cash"
  aCash <- issueCash cashI w.bank w.firmA "A-cash" 70.0

  -- operator's settlement authority over the bank's holdings
  _ <- submit w.bank do createCmd SettlementAuthority with custodian = w.bank; coordinator = w.operator
  auth <- findAuth w.bank w.operator

  -- the confidential obligation book (each disclosed only to its 2 firms + operator)
  o1 <- mkObligation w.firmA w.firmB w.operator w.usd 100.0 "A->B inv1"
  o2 <- mkObligation w.firmB w.firmC w.operator w.usd 100.0 "B->C inv2"
  o3 <- mkObligation w.firmC w.firmA w.operator w.usd 80.0 "C->A inv3"
  o4 <- mkObligation w.firmA w.firmC w.operator w.usd 50.0 "A->C inv4"
  o5 <- mkObligation w.firmC w.firmB w.operator w.usd 30.0 "C->B inv5"

  let obls = [o1, o2, o3, o4, o5]
      facts =
        [ NetTransfer w.firmA w.firmB 100.0 (Some "USD")
        , NetTransfer w.firmB w.firmC 100.0 (Some "USD")
        , NetTransfer w.firmC w.firmA 80.0 (Some "USD")
        , NetTransfer w.firmA w.firmC 50.0 (Some "USD")
        , NetTransfer w.firmC w.firmB 30.0 (Some "USD") ]
      -- agent-computed minimal residuals: A->C 40, A->B 30
      legAC = Leg with sender = w.firmA; receiver = w.firmC; custodian = w.bank; instrument = w.usd; amount = 40.0; senderAccountId = Id "A-cash"; receiverAccountId = Id "C-cash"
      legAB = Leg with sender = w.firmA; receiver = w.firmB; custodian = w.bank; instrument = w.usd; amount = 30.0; senderAccountId = Id "A-cash"; receiverAccountId = Id "B-cash"
      residualLegs = [ legAC, legAB ]

  -- operator proposes the netting batch
  batch <- submit w.operator do
    createCmd NettingBatch with
      operator = w.operator; obligations = obls; obligationFacts = facts
      residualLegs; cashInstrument = w.usd; creditLimits = Some []; fxRates = None; liquidityFloors = None; balanceFacts = None; valuationCurrency = None
      parties = Set.fromList [w.firmA, w.firmB, w.firmC]
      regulator = Some w.regulator; status = Pending

  -- A's single cash holding (70) funds both residual legs (40 + 30). Lock it once
  -- per leg by splitting: here we model two legs from the same owner by locking the
  -- holding and letting SettleTransfer move sub-amounts. For the test we fund each
  -- leg with its own holding for clarity.
  aCash40 <- issueCash cashI w.bank w.firmA "A-cash" 40.0
  aCash30 <- issueCash cashI w.bank w.firmA "A-cash" 30.0
  locked40 <- submitMulti [w.bank, w.firmA] [] do
    exerciseCmd aCash40 LockHolding with locker = w.operator; context = "net1"
  locked30 <- submitMulti [w.bank, w.firmA] [] do
    exerciseCmd aCash30 LockHolding with locker = w.operator; context = "net1"
  let allocs =
        [ AllocatedLeg with leg = legAC; holdingCid = locked40; authorityCid = auth
        , AllocatedLeg with leg = legAB; holdingCid = locked30; authorityCid = auth ]

  -- settle atomically: discharge all 5 obligations + move the 2 residual legs
  result <- submitMulti (w.operator :: [w.firmA, w.firmB, w.firmC]) [] do
    exerciseCmd batch SettleNetting with allocations = allocs

  result.obligationsDischarged === 5
  result.residualsSettled === 2
  result.grossValue === 360.0
  result.netValue === 70.0

  -- all obligations are gone (discharged)
  forA_ obls $ \o -> do
    still <- queryContractId w.operator o
    assertMsg "obligation must be discharged" (isNone still)

  debug "testThreePartyNetting PASSED: 360 gross netted to 70 residual, 5 obligations discharged atomically"
  pure ()

-- | ADVERSARIAL: a proposal that violates conservation (residual doesn't match the
--   netted positions) must be REJECTED on-ledger.
testNettingRejectsValueViolation : Script ()
testNettingRejectsValueViolation = do
  w <- setupNetWorld
  cashI <- submit w.bank do
    createCmd Instrument with
      depository = w.bank; issuer = w.bank; id = Id "USD"; version = "1"
      holdingStandard = TransferableFungible
      description = "USD"; observers = Set.empty
  mkCashAccount w.bank w.firmA "A-cash"
  mkCashAccount w.bank w.firmB "B-cash"
  _ <- submit w.bank do createCmd SettlementAuthority with custodian = w.bank; coordinator = w.operator
  auth <- findAuth w.bank w.operator

  o1 <- mkObligation w.firmA w.firmB w.operator w.usd 100.0 "A->B"
  -- net: A owes B 100. A FRAUDULENT proposal claims only 10 needs to move.
  let facts = [ NetTransfer w.firmA w.firmB 100.0 (Some "USD") ]
      badLeg = Leg with sender = w.firmA; receiver = w.firmB; custodian = w.bank; instrument = w.usd; amount = 10.0; senderAccountId = Id "A-cash"; receiverAccountId = Id "B-cash"  -- under-settles by 90!
      badLegs = [ badLeg ]
  batch <- submit w.operator do
    createCmd NettingBatch with
      operator = w.operator; obligations = [o1]; obligationFacts = facts
      residualLegs = badLegs; cashInstrument = w.usd; creditLimits = Some []; fxRates = None; liquidityFloors = None; balanceFacts = None; valuationCurrency = None
      parties = Set.fromList [w.firmA, w.firmB]
      regulator = None; status = Pending

  badCash <- issueCash cashI w.bank w.firmA "A-cash" 10.0
  lockedBad <- submitMulti [w.bank, w.firmA] [] do
    exerciseCmd badCash LockHolding with locker = w.operator; context = "bad"
  let allocs = [ AllocatedLeg with leg = badLeg; holdingCid = lockedBad; authorityCid = auth ]

  -- MUST FAIL: conservation guard rejects under-settlement
  submitMultiMustFail (w.operator :: [w.firmA, w.firmB]) [] do
    exerciseCmd batch SettleNetting with allocations = allocs

  debug "testNettingRejectsValueViolation PASSED: on-ledger conservation guard rejected under-settlement"
  pure ()

-- | PRIVACY: each firm sees only the obligations it is a counterparty to — never
--   the whole book. Only the operator sees everything.
testNettingPrivacy : Script ()
testNettingPrivacy = do
  w <- setupNetWorld
  _ <- mkObligation w.firmA w.firmB w.operator w.usd 100.0 "A->B"
  _ <- mkObligation w.firmB w.firmC w.operator w.usd 100.0 "B->C"
  _ <- mkObligation w.firmC w.firmA w.operator w.usd 80.0 "C->A"

  aSees <- query @Obligation w.firmA
  bSees <- query @Obligation w.firmB
  opSees <- query @Obligation w.operator
  outSees <- query @Obligation w.outsider

  -- A is party to A->B and C->A only (2); B to A->B and B->C (2);
  -- operator sees all 3; outsider sees none.
  length aSees === 2
  length bSees === 2
  length opSees === 3
  length outSees === 0

  debug "testNettingPrivacy PASSED: firms see only their own obligations (A:2 B:2 operator:3 outsider:0)"
  pure ()

-- | MULTI-CURRENCY: a book with both USD and EUR obligations nets each currency
--   INDEPENDENTLY and settles atomically. A USD residual can never offset a EUR
--   debt — the per-currency conservation guard enforces this on-ledger.
--   Book:  USD: A owes B 100 ; B owes A 40   -> A net USD -60 (pays B 60)
--          EUR: B owes A 50                  -> B net EUR -50 (pays A 50)
--   Residuals: A->B 60 USD, B->A 50 EUR. Both settle in ONE atomic transaction.
testMultiCurrencyNetting : Script ()
testMultiCurrencyNetting = do
  w <- setupNetWorld
  let eur = InstrumentKey with
        depository = w.bank; issuer = w.bank; id = Id "EUR"; version = "1"
        holdingStandard = TransferableFungible

  usdI <- submit w.bank do
    createCmd Instrument with
      depository = w.bank; issuer = w.bank; id = Id "USD"; version = "1"
      holdingStandard = TransferableFungible; description = "USD"; observers = Set.empty
  eurI <- submit w.bank do
    createCmd Instrument with
      depository = w.bank; issuer = w.bank; id = Id "EUR"; version = "1"
      holdingStandard = TransferableFungible; description = "EUR"; observers = Set.empty
  mkCashAccount w.bank w.firmA "A-cash"
  mkCashAccount w.bank w.firmB "B-cash"

  _ <- submit w.bank do createCmd SettlementAuthority with custodian = w.bank; coordinator = w.operator
  auth <- findAuth w.bank w.operator

  -- the cross-currency book
  oUsd1 <- mkObligation w.firmA w.firmB w.operator w.usd 100.0 "A->B 100 USD"
  oUsd2 <- mkObligation w.firmB w.firmA w.operator w.usd 40.0  "B->A 40 USD"
  oEur1 <- mkObligation w.firmB w.firmA w.operator eur 50.0    "B->A 50 EUR"

  let obls = [oUsd1, oUsd2, oEur1]
      facts =
        [ NetTransfer w.firmA w.firmB 100.0 (Some "USD")
        , NetTransfer w.firmB w.firmA 40.0  (Some "USD")
        , NetTransfer w.firmB w.firmA 50.0  (Some "EUR") ]
      -- residuals: A pays B 60 USD ; B pays A 50 EUR
      legUsd = Leg with sender = w.firmA; receiver = w.firmB; custodian = w.bank; instrument = w.usd; amount = 60.0; senderAccountId = Id "A-cash"; receiverAccountId = Id "B-cash"
      legEur = Leg with sender = w.firmB; receiver = w.firmA; custodian = w.bank; instrument = eur; amount = 50.0; senderAccountId = Id "B-cash"; receiverAccountId = Id "A-cash"
      residualLegs = [legUsd, legEur]

  batch <- submit w.operator do
    createCmd NettingBatch with
      operator = w.operator; obligations = obls; obligationFacts = facts
      residualLegs; cashInstrument = w.usd; creditLimits = Some []; fxRates = None; liquidityFloors = None; balanceFacts = None; valuationCurrency = None
      parties = Set.fromList [w.firmA, w.firmB]
      regulator = Some w.regulator; status = Pending

  -- fund each residual sender in the right currency
  aUsd <- issueCash usdI w.bank w.firmA "A-cash" 60.0
  bEur <- submitMulti [w.bank, w.firmB] [] do
    exerciseCmd eurI Issue with custodian = w.bank; owner = w.firmB; accountId = Id "B-cash"; amount = 50.0
  lockedUsd <- submitMulti [w.bank, w.firmA] [] do
    exerciseCmd aUsd LockHolding with locker = w.operator; context = "mc"
  lockedEur <- submitMulti [w.bank, w.firmB] [] do
    exerciseCmd bEur LockHolding with locker = w.operator; context = "mc"
  let allocs =
        [ AllocatedLeg with leg = legUsd; holdingCid = lockedUsd; authorityCid = auth
        , AllocatedLeg with leg = legEur; holdingCid = lockedEur; authorityCid = auth ]

  result <- submitMulti (w.operator :: [w.firmA, w.firmB]) [] do
    exerciseCmd batch SettleNetting with allocations = allocs

  result.obligationsDischarged === 3
  result.residualsSettled === 2

  debug "testMultiCurrencyNetting PASSED: USD and EUR netted independently, settled atomically (A->B 60 USD, B->A 50 EUR)"
  pure ()

-- | CREDIT LIMIT: an on-ledger bilateral credit limit REJECTS a netting plan whose
--   residual would over-expose one party to a single counterparty — even though the
--   plan is perfectly value-conserving. This is the beat that makes the ledger
--   enforce a fintech's OWN risk constraint, not just accounting identity.
--   Book: A owes B 100 (net: A pays B 100). FirmA set a self-limit of 50 owed to B.
--   The only conserving plan is A->B 100 — which BREACHES the 50 cap -> rejected.
testNettingRejectsCreditLimitBreach : Script ()
testNettingRejectsCreditLimitBreach = do
  w <- setupNetWorld
  cashI <- submit w.bank do
    createCmd Instrument with
      depository = w.bank; issuer = w.bank; id = Id "USD"; version = "1"
      holdingStandard = TransferableFungible; description = "USD"; observers = Set.empty
  mkCashAccount w.bank w.firmA "A-cash"
  mkCashAccount w.bank w.firmB "B-cash"
  _ <- submit w.bank do createCmd SettlementAuthority with custodian = w.bank; coordinator = w.operator
  auth <- findAuth w.bank w.operator

  o1 <- mkObligation w.firmA w.firmB w.operator w.usd 100.0 "A->B 100"

  -- FirmA accepts an on-ledger cap: it may owe FirmB at most 50 USD post-netting.
  limit <- submitMulti [w.firmA, w.operator] [] do
    createCmd CreditLimit with
      operator = w.operator; from = w.firmA; to = w.firmB; currency = "USD"; limit = 50.0

  let facts = [ NetTransfer w.firmA w.firmB 100.0 (Some "USD") ]
      leg = Leg with sender = w.firmA; receiver = w.firmB; custodian = w.bank; instrument = w.usd; amount = 100.0; senderAccountId = Id "A-cash"; receiverAccountId = Id "B-cash"
  batch <- submit w.operator do
    createCmd NettingBatch with
      operator = w.operator; obligations = [o1]; obligationFacts = facts
      residualLegs = [leg]; cashInstrument = w.usd; creditLimits = Some [limit]; fxRates = None; liquidityFloors = None; balanceFacts = None; valuationCurrency = None
      parties = Set.fromList [w.firmA, w.firmB]
      regulator = None; status = Pending

  cash <- issueCash cashI w.bank w.firmA "A-cash" 100.0
  locked <- submitMulti [w.bank, w.firmA] [] do
    exerciseCmd cash LockHolding with locker = w.operator; context = "cl"
  let allocs = [ AllocatedLeg with leg; holdingCid = locked; authorityCid = auth ]

  -- MUST FAIL: the on-ledger credit-limit guard rejects the over-exposure
  submitMultiMustFail (w.operator :: [w.firmA, w.firmB]) [] do
    exerciseCmd batch SettleNetting with allocations = allocs

  -- and the obligation is UNTOUCHED (atomic rollback): A still sees it
  still <- queryContractId w.firmA o1
  assertMsg "obligation must survive the rejected settle" (not (isNone still))

  debug "testNettingRejectsCreditLimitBreach PASSED: on-ledger credit limit rejected the over-exposing plan; nothing settled"
  pure ()

-- | CROSS-CURRENCY netting at a CO-SIGNED FX rate. FirmA owes FirmB 100 USD; FirmB
--   owes FirmA 50 EUR. With an agreed rate 1 EUR = 1.2 USD, FirmB's 50 EUR = 60 USD,
--   so the net VALUE is A owes B 40 USD. Settles as a single 40 USD residual — the
--   EUR leg is netted against the USD leg AT THE RATE BOTH PARTIES SIGNED. This is
--   trustless cross-currency netting: no party can be cheated by an operator-chosen
--   rate, because the rate contract is co-signed by every party in the book.
testCrossCurrencyNettingAtAgreedRate : Script ()
testCrossCurrencyNettingAtAgreedRate = do
  w <- setupNetWorld
  let eur = InstrumentKey with
        depository = w.bank; issuer = w.bank; id = Id "EUR"; version = "1"
        holdingStandard = TransferableFungible
  usdI <- submit w.bank do
    createCmd Instrument with
      depository = w.bank; issuer = w.bank; id = Id "USD"; version = "1"
      holdingStandard = TransferableFungible; description = "USD"; observers = Set.empty
  _ <- submit w.bank do
    createCmd Instrument with
      depository = w.bank; issuer = w.bank; id = Id "EUR"; version = "1"
      holdingStandard = TransferableFungible; description = "EUR"; observers = Set.empty
  mkCashAccount w.bank w.firmA "A-cash"
  mkCashAccount w.bank w.firmB "B-cash"
  _ <- submit w.bank do createCmd SettlementAuthority with custodian = w.bank; coordinator = w.operator
  auth <- findAuth w.bank w.operator

  -- co-signed FX rate: 1 EUR = 1.2 USD, agreed by both firms + operator
  let bookParties = Set.fromList [w.firmA, w.firmB]
  fx <- submitMulti [w.firmA, w.firmB, w.operator] [] do
    createCmd FXRate with
      operator = w.operator; base = "EUR"; quote = "USD"; rate = 1.2
      parties = bookParties

  oUsd <- mkObligation w.firmA w.firmB w.operator w.usd 100.0 "A->B 100 USD"
  oEur <- mkObligation w.firmB w.firmA w.operator eur 50.0   "B->A 50 EUR"

  let obls = [oUsd, oEur]
      facts = [ NetTransfer w.firmA w.firmB 100.0 (Some "USD")
              , NetTransfer w.firmB w.firmA 50.0  (Some "EUR") ]
      -- value net: A owes B 100 USD; B owes A 50 EUR = 60 USD -> A net owes B 40 USD
      legUsd = Leg with sender = w.firmA; receiver = w.firmB; custodian = w.bank; instrument = w.usd; amount = 40.0; senderAccountId = Id "A-cash"; receiverAccountId = Id "B-cash"
      residualLegs = [legUsd]

  batch <- submit w.operator do
    createCmd NettingBatch with
      operator = w.operator; obligations = obls; obligationFacts = facts
      residualLegs; cashInstrument = w.usd; creditLimits = Some []
      fxRates = Some [fx]; liquidityFloors = None; balanceFacts = None
      valuationCurrency = Some "USD"
      parties = bookParties
      regulator = Some w.regulator; status = Pending

  aUsd <- issueCash usdI w.bank w.firmA "A-cash" 40.0
  locked <- submitMulti [w.bank, w.firmA] [] do
    exerciseCmd aUsd LockHolding with locker = w.operator; context = "fx"
  let allocs = [ AllocatedLeg with leg = legUsd; holdingCid = locked; authorityCid = auth ]

  result <- submitMulti (w.operator :: [w.firmA, w.firmB]) [] do
    exerciseCmd batch SettleNetting with allocations = allocs

  result.obligationsDischarged === 2
  result.residualsSettled === 1
  debug "testCrossCurrencyNettingAtAgreedRate PASSED: EUR netted against USD at the co-signed 1.2 rate -> single 40 USD residual"
  pure ()

-- | CROSS-CURRENCY netting must FAIL if the residual doesn't conserve VALUE at the
--   agreed rate. Same book, but the operator proposes only 30 USD (should be 40).
testCrossCurrencyRejectsValueViolation : Script ()
testCrossCurrencyRejectsValueViolation = do
  w <- setupNetWorld
  let eur = InstrumentKey with
        depository = w.bank; issuer = w.bank; id = Id "EUR"; version = "1"
        holdingStandard = TransferableFungible
  usdI <- submit w.bank do
    createCmd Instrument with
      depository = w.bank; issuer = w.bank; id = Id "USD"; version = "1"
      holdingStandard = TransferableFungible; description = "USD"; observers = Set.empty
  _ <- submit w.bank do
    createCmd Instrument with
      depository = w.bank; issuer = w.bank; id = Id "EUR"; version = "1"
      holdingStandard = TransferableFungible; description = "EUR"; observers = Set.empty
  mkCashAccount w.bank w.firmA "A-cash"
  mkCashAccount w.bank w.firmB "B-cash"
  _ <- submit w.bank do createCmd SettlementAuthority with custodian = w.bank; coordinator = w.operator
  auth <- findAuth w.bank w.operator
  let bookParties = Set.fromList [w.firmA, w.firmB]
  fx <- submitMulti [w.firmA, w.firmB, w.operator] [] do
    createCmd FXRate with
      operator = w.operator; base = "EUR"; quote = "USD"; rate = 1.2; parties = bookParties
  oUsd <- mkObligation w.firmA w.firmB w.operator w.usd 100.0 "A->B 100 USD"
  oEur <- mkObligation w.firmB w.firmA w.operator eur 50.0   "B->A 50 EUR"
  let facts = [ NetTransfer w.firmA w.firmB 100.0 (Some "USD")
              , NetTransfer w.firmB w.firmA 50.0  (Some "EUR") ]
      badLeg = Leg with sender = w.firmA; receiver = w.firmB; custodian = w.bank; instrument = w.usd; amount = 30.0; senderAccountId = Id "A-cash"; receiverAccountId = Id "B-cash"  -- should be 40
  batch <- submit w.operator do
    createCmd NettingBatch with
      operator = w.operator; obligations = [oUsd, oEur]; obligationFacts = facts
      residualLegs = [badLeg]; cashInstrument = w.usd; creditLimits = Some []
      fxRates = Some [fx]; liquidityFloors = None; balanceFacts = None
      valuationCurrency = Some "USD"
      parties = bookParties; regulator = None; status = Pending
  bad <- issueCash usdI w.bank w.firmA "A-cash" 30.0
  locked <- submitMulti [w.bank, w.firmA] [] do exerciseCmd bad LockHolding with locker = w.operator; context = "fxbad"
  let allocs = [ AllocatedLeg with leg = badLeg; holdingCid = locked; authorityCid = auth ]
  submitMultiMustFail (w.operator :: [w.firmA, w.firmB]) [] do
    exerciseCmd batch SettleNetting with allocations = allocs
  debug "testCrossCurrencyRejectsValueViolation PASSED: value-conservation guard rejected the under-valued cross-currency residual"
  pure ()

-- | LIQUIDITY FLOOR: a netting plan that would drain a party below its on-ledger
--   minimum balance is REJECTED. FirmA owes FirmB 100; A's net residual is -100 USD.
--   A holds 120 pre-settle but has a 50 USD floor -> post-settle 20 < 50 -> rejected.
testNettingRejectsLiquidityFloorBreach : Script ()
testNettingRejectsLiquidityFloorBreach = do
  w <- setupNetWorld
  cashI <- submit w.bank do
    createCmd Instrument with
      depository = w.bank; issuer = w.bank; id = Id "USD"; version = "1"
      holdingStandard = TransferableFungible; description = "USD"; observers = Set.empty
  mkCashAccount w.bank w.firmA "A-cash"
  mkCashAccount w.bank w.firmB "B-cash"
  _ <- submit w.bank do createCmd SettlementAuthority with custodian = w.bank; coordinator = w.operator
  auth <- findAuth w.bank w.operator

  o1 <- mkObligation w.firmA w.firmB w.operator w.usd 100.0 "A->B 100"
  -- FirmA sets a 50 USD operating floor
  floor <- submitMulti [w.firmA, w.operator] [] do
    createCmd LiquidityFloor with operator = w.operator; party = w.firmA; currency = "USD"; floor = 50.0

  let facts = [ NetTransfer w.firmA w.firmB 100.0 (Some "USD") ]
      leg = Leg with sender = w.firmA; receiver = w.firmB; custodian = w.bank; instrument = w.usd; amount = 100.0; senderAccountId = Id "A-cash"; receiverAccountId = Id "B-cash"
      -- A holds 120 pre-settle; paying 100 leaves 20 < 50 floor
      bal = [ BalanceFact with party = w.firmA; currency = "USD"; balance = 120.0 ]
  batch <- submit w.operator do
    createCmd NettingBatch with
      operator = w.operator; obligations = [o1]; obligationFacts = facts
      residualLegs = [leg]; cashInstrument = w.usd; creditLimits = Some []
      fxRates = None; liquidityFloors = Some [floor]; balanceFacts = Some bal
      valuationCurrency = None
      parties = Set.fromList [w.firmA, w.firmB]; regulator = None; status = Pending

  cash <- issueCash cashI w.bank w.firmA "A-cash" 100.0
  locked <- submitMulti [w.bank, w.firmA] [] do exerciseCmd cash LockHolding with locker = w.operator; context = "lf"
  let allocs = [ AllocatedLeg with leg; holdingCid = locked; authorityCid = auth ]

  submitMultiMustFail (w.operator :: [w.firmA, w.firmB]) [] do
    exerciseCmd batch SettleNetting with allocations = allocs

  still <- queryContractId w.firmA o1
  assertMsg "obligation must survive the rejected settle" (not (isNone still))
  debug "testNettingRejectsLiquidityFloorBreach PASSED: on-ledger liquidity floor rejected the draining plan; nothing settled"
  pure ()

-- | FX rate NOT co-signed by all parties must be REFUSED. Same cross-currency book,
--   but the FXRate omits FirmB -> the settle cannot trust it -> rejected.
testCrossCurrencyRejectsUnsignedRate : Script ()
testCrossCurrencyRejectsUnsignedRate = do
  w <- setupNetWorld
  let eur = InstrumentKey with
        depository = w.bank; issuer = w.bank; id = Id "EUR"; version = "1"
        holdingStandard = TransferableFungible
  usdI <- submit w.bank do
    createCmd Instrument with
      depository = w.bank; issuer = w.bank; id = Id "USD"; version = "1"
      holdingStandard = TransferableFungible; description = "USD"; observers = Set.empty
  _ <- submit w.bank do
    createCmd Instrument with
      depository = w.bank; issuer = w.bank; id = Id "EUR"; version = "1"
      holdingStandard = TransferableFungible; description = "EUR"; observers = Set.empty
  mkCashAccount w.bank w.firmA "A-cash"
  mkCashAccount w.bank w.firmB "B-cash"
  _ <- submit w.bank do createCmd SettlementAuthority with custodian = w.bank; coordinator = w.operator
  auth <- findAuth w.bank w.operator
  -- FX rate signed by ONLY FirmA + operator (NOT FirmB) -> not mutually agreed
  fx <- submitMulti [w.firmA, w.operator] [] do
    createCmd FXRate with
      operator = w.operator; base = "EUR"; quote = "USD"; rate = 1.2
      parties = Set.fromList [w.firmA]
  oUsd <- mkObligation w.firmA w.firmB w.operator w.usd 100.0 "A->B 100 USD"
  oEur <- mkObligation w.firmB w.firmA w.operator eur 50.0   "B->A 50 EUR"
  let facts = [ NetTransfer w.firmA w.firmB 100.0 (Some "USD")
              , NetTransfer w.firmB w.firmA 50.0  (Some "EUR") ]
      legUsd = Leg with sender = w.firmA; receiver = w.firmB; custodian = w.bank; instrument = w.usd; amount = 40.0; senderAccountId = Id "A-cash"; receiverAccountId = Id "B-cash"
  batch <- submit w.operator do
    createCmd NettingBatch with
      operator = w.operator; obligations = [oUsd, oEur]; obligationFacts = facts
      residualLegs = [legUsd]; cashInstrument = w.usd; creditLimits = Some []
      fxRates = Some [fx]; liquidityFloors = None; balanceFacts = None
      valuationCurrency = Some "USD"
      parties = Set.fromList [w.firmA, w.firmB]; regulator = None; status = Pending
  aUsd <- issueCash usdI w.bank w.firmA "A-cash" 40.0
  locked <- submitMulti [w.bank, w.firmA] [] do exerciseCmd aUsd LockHolding with locker = w.operator; context = "fxun"
  let allocs = [ AllocatedLeg with leg = legUsd; holdingCid = locked; authorityCid = auth ]
  submitMultiMustFail (w.operator :: [w.firmA, w.firmB]) [] do
    exerciseCmd batch SettleNetting with allocations = allocs
  debug "testCrossCurrencyRejectsUnsignedRate PASSED: an FX rate not co-signed by all parties was refused"
  pure ()

-- | NETTING CYCLE LIFECYCLE: the rail's operating rhythm, enforced on-ledger.
--   Open -> Close -> RecordSettlement -> RollForward -> (next) Open. Proves the state
--   machine is real: you cannot record settlement on an open cycle, cannot roll
--   forward before settling, and the successor cycle increments the number and is Open.
testNettingCycleLifecycle : Script ()
testNettingCycleLifecycle = do
  w <- setupNetWorld

  -- open cycle 1
  c1 <- submit w.operator do
    createCmd NettingCycle with
      operator = w.operator; cycleNumber = 1; status = CycleOpen
      regulator = Some w.regulator
      settledCount = 0; deferredCount = 0; settledValue = 0.0; deferredValue = 0.0

  -- you CANNOT record settlement while still Open (must close first)
  submitMustFail w.operator do
    exerciseCmd c1 RecordSettlement with sc = 1; dc = 0; sv = 10.0; dv = 0.0

  -- close the book: Open -> Closed
  c1c <- submit w.operator do exerciseCmd c1 CloseCycle

  -- you CANNOT roll forward before settling
  submitMustFail w.operator do exerciseCmd c1c RollForward

  -- record the maximal-netting outcome: settled 1 (30), deferred 1 (25)
  c1s <- submit w.operator do
    exerciseCmd c1c RecordSettlement with sc = 1; dc = 1; sv = 30.0; dv = 25.0

  -- the cycle now carries the durable, regulator-observable result
  Some rec <- queryContractId w.operator c1s
  rec.status === CycleSettled
  rec.settledCount === 1
  rec.deferredCount === 1
  rec.settledValue === 30.0
  rec.deferredValue === 25.0

  -- the REGULATOR can see the settled cycle (scoped oversight)
  regView <- queryContractId w.regulator c1s
  assertMsg "regulator must observe the cycle result" (not (isNone regView))

  -- roll forward: Settled cycle 1 -> Open cycle 2 (the deferred 25 is caught next)
  c2 <- submit w.operator do exerciseCmd c1s RollForward
  Some next <- queryContractId w.operator c2
  next.cycleNumber === 2
  next.status === CycleOpen
  next.settledCount === 0   -- fresh session
  next.deferredCount === 0

  debug "testNettingCycleLifecycle PASSED: Open->Close->Settle->RollForward enforced on-ledger; deferred value rolls to cycle 2"
  pure ()
